DEV_MODE=false
GOOGLE_API_KEY=your_google_api_key_here

# Mindra provider mode
# local = use internal graph orchestration
# api   = call external Mindra endpoint
MINDRA_PROVIDER=local
# Option A: full run endpoint URL
# Example: https://api.mindra.co/v1/workflows/your-workflow-slug/run
MINDRA_API_URL=
# Option B: provide slug only (backend will build URL automatically)
MINDRA_WORKFLOW_SLUG=your-workflow-slug
# Dedicated workflow for Twitter posting (optional; falls back to default Mindra URL/slug)
MINDRA_TWITTER_API_URL=
MINDRA_TWITTER_WORKFLOW_SLUG=twitter-feed-agent
MINDRA_API_KEY=your_mindra_api_key_here
MINDRA_TIMEOUT_SECONDS=180
MINDRA_CHILD_NODE_ENABLED=true
MINDRA_TWITTER_AGENT_ENABLED=true
MINDRA_STREAM_WAIT_SECONDS=90

# Trust Net free reviews API base URL
TRUST_NET_BASE_URL=https://trust-net-mcp.rikenshah-02.workers.dev

