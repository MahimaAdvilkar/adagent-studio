{
  "version": 2,
  "installCommand": "npm --prefix adagent-frontend ci",
  "buildCommand": "npm --prefix adagent-frontend run build",
  "outputDirectory": "adagent-frontend/dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/src/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
